%%{init: {'theme': 'default', 'themeVariables': {'activationBkgColor': '#d9ead3', 'activationBorderColor': '#6aa84f'}}}%%
sequenceDiagram
    actor User as Employee
    participant D as Dorm
    participant E as Employee
    participant R as Resident
    participant I as Invoice

    User ->>+ D: add_strike(employee_ID_input)

    %% 1. ตรวจสอบ Employee
    D ->>+ E: search_employee_by_id(employee_ID_input)
    E -->>- D: return employee instance

    opt not found employee
        D -->> User: raise PermissionError
    end

    %% 2. วนทุก Resident
    loop for resident in residents
        D ->> D: max_strike = 0

        %% 3. วนทุก Invoice ของ Resident
        loop for invoice in resident.invoices
            D ->>+ I: check invoice.status
            I -->>- D: return status

            opt status == PAID
                D ->> D: continue
            end

            D ->>+ I: get date_create
            I -->>- D: return date_create

            D ->> D: calculate months_old

            alt months_old >= 3
                D ->> D: strike = 3
            else months_old >= 2
                D ->> D: strike = 2
            else months_old >= 1
                D ->> D: strike = 1
            else
                D ->> D: strike = 0
            end

            opt strike > max_strike
                D ->> D: max_strike = strike
            end
        end

        %% 4. add strike ให้ resident
        opt max_strike > 0
            D ->>+ R: add_strike(max_strike)
            R ->> R: update strike
            R -->>- D: done
        end

        %% 5. เช็ค blacklist
        opt resident.strike >= 3
            D ->> D: add to residents_to_blacklist
        end
    end

    %% 6. ย้าย resident ไป blacklist
    loop for resident in residents_to_blacklist
        D ->> D: remove from residents
        D ->> D: add to blacklist
    end

    D -->>- User: return add_strike success