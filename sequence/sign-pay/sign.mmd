sequenceDiagram
autonumber

participant R as Resident
participant API as FastAPI
participant D as DormSystem
participant C as LeaseContract
participant I as Invoice

R->>API: POST /sign_contract\n(contract_id)
activate API

API->>D: sign_contract(contract_id)
activate D

D->>D: get_contract_by_id()

alt contract not found
    D-->>API: LookupError
    API-->>R: 400 error
else contract found

    D->>C: validate_for_signing()
    activate C

    alt status != DRAFT
        C-->>D: ValueError
        D-->>API: error
        API-->>R: cannot sign
    else status valid
        C-->>D: validation OK
    end

    deactivate C

    D->>C: get_amount()
    C-->>D: room.price

    D->>I: create_invoice(amount, CONTRACT)
    activate I
    I-->>D: invoiceObj
    deactivate I

    D->>C: set status = PENDING_SIGN

    D-->>API: invoiceObj
end

API-->>R: invoice_id, amount, invoice_type
deactivate API