---
config:
    layout: elk
---
%%{init: {'theme': 'forest', 'classDiagram': {'curve': 'linear', 'padding': 20}}}%%

classDiagram
    %% ========== ABSTRACT BASE CLASSES ==========

    class Member {
        <<abstract>>
        -MemberType member_type
        -float discount
        +member_type()
        +discount()
    }

    class Payment_Method {
        <<abstract>>
        +format_payment_method(input)$
        +payment_format()*
        +check_format(raw)*
    }

    class Staff {
        -str id
        -str name
        -str phone_number
        -str status
        -datetime hire_date
        -Task current_task
        +assign_task(task)
        +complete_task()
        +update_status(task, status)
    }

    class ShareFacility {
        -str id
        -ShareFacilityStatus status
        -list facility_log
        -float cost
        +cost()
        +create_booking(resident_id, facility_id, building_id, time)
        +create_share_facility_invoice(resident_id, booking)
    }

    %% ========== MEMBER SUBCLASSES ==========

    class Standard_Member {
        discount = 0.02
    }
    class Plus_Member {
        discount = 0.05
    }
    class Platinum_Member {
        discount = 0.10
    }

    Member <|-- Standard_Member
    Member <|-- Plus_Member
    Member <|-- Platinum_Member

    %% ========== PAYMENT METHOD SUBCLASSES ==========

    class Bank_Account {
        type = "bank_account"
        dorm_bank_account_number
        bank
        +payment_format()
        +check_format(raw)
    }
    class Card {
        type = "card"
        +payment_format()
        +check_format(raw)
    }

    Payment_Method <|-- Bank_Account
    Payment_Method <|-- Card

    %% ========== STAFF SUBCLASSES ==========

    class Cleaner {
        -list cleaning_supplies_list
        -list assigned_rooms
        +search_cleaning_ticket_by_room_id(room_id)
        +clean_room(room, ticket)
        +finished_cleaning(room)
        +complete_task()
    }
    class Technician {
        -list capabilities
        +show_all_mt(building_id)
        +assign_ticket(ticket)
        +start_maintenance(notes)
        +complete_task()
    }
    class ElectricalTech {
        -str certification_no
        +start_maintenance(notes)
    }
    class PlumbingTech {
        -str water_meter_tool
        +start_maintenance(notes)
    }
    class ACTech {
        -float gas_level_refrigerant
        MIN_GAS_LEVEL = 20.0
        +start_maintenance(notes)
        +complete_task()
    }

    Staff <|-- Cleaner
    Staff <|-- Technician
    Technician <|-- ElectricalTech
    Technician <|-- PlumbingTech
    Technician <|-- ACTech

    %% ========== SHARE FACILITY SUBCLASSES ==========

    class WashingMachine {
        cost = 50
    }
    class MeetingRoom {
        cost = 100
    }

    ShareFacility <|-- WashingMachine
    ShareFacility <|-- MeetingRoom

    %% ========== CORE DOMAIN CLASSES ==========

    class Dorm {
        -str name
        -list buildings
        -list residents
        -list employees
        -list technicians
        -list cleaner
        -list blacklist
        +sign_in(name, email, phone)
        +show_success(success)
        +show_error(error)
        +add_employee(employee)
        +add_resident(resident)
        +add_operation_staff(employee)
        +add_technician(technician)
        +add_cleaner(cleaner)
        +add_building(building)
        +search_employee_by_id(employee_id)
        +search_resident_by_id(resident_id)
        +search_room_by_id(room_id)
        +search_room_by_contracts(resident, room_id)
        +search_building_by_id(building_id)
        +search_technician_by_id(technician_id)
        +search_cleaner_by_id(cleaner_id)
        +clean_room_workflow(cleaner_id, room_id)
        +start_cleaning_workflow(cleaner_id, room_id)
        +finish_cleaning_workflow(cleaner_id, room_id)
        +search_contract_by_id(contract_id)
        +search_invoice_by_id(invoice_id)
        +search_resident_by_room_id(room_id)
        +search_available_employee()
        +request_booking(resident_id, building_id, room_type)
        +sign_contract(contract_id)
        +pay_contract_invoice(invoice_id)
        +complete_handover(contract_id)
        +change_contract(...)
        +request_maintenance(resident_id, room_id, issue_category)
        +start_maintenance_workflow(technician_id, notes)
        +finish_maintenance_workflow(technician_id)
        +complete_task_workflow(staff_id)
        +request_cleaning_room(resident_id, room_id)
        +booking_share_facility(...)
        +system_contract_invoice(employee_id)
        +select_payment_method_and_invoices(...)
        +payment_system(resident_id, paymentdata)
        +create_member(resident_id, type_member)
        +add_strike(employee_id)
        +display_invoice(resident_id)
        +display_receipt(resident_id)
    }

    class Building {
        -str id
        -int floor_count
        -list rooms
        -list washing_machines
        -list meeting_rooms
        -list lockers
        +add_room(room)
        +add_washing_machine(wm)
        +add_meeting_room(mr)
        +find_and_hold_available_room_by_type(room_type)
        +get_share_facility_by_id(facility_id)
    }

    class Room {
        -str id
        -Building building
        -int floor
        -RoomType type
        -RoomStatus status
        -float monthly_rent
        -list maintenance_tickets
        -list cleaning_tickets
        -list room_log
        -float electric_cost
        -float water_cost
        -datetime hold_expiry
        +define_monthly_rent(room_type)
        +add_maintenance_ticket(ticket)
        +update_meter(elect, water)
        +record_handover(elect, water)
        +hold(hours)
        +is_hold_expired()
    }

    class Resident {
        -str id
        -str name
        -str email
        -str phone_number
        -AccountStatus status
        -int strike
        -Member member
        -Payment payment
        -datetime date_create
        -list room_bookings
        -list contracts
        -list invoices
        -list receipts
        -list booking_share_facility_list
        +add_contract(contract)
        +add_invoice(invoice)
        +add_facility_booking(facility_booking)
        +add_booking_share_facility(booking)
        +get_facility_bookings()
        +set_member(member)
        +set_payment(method, invoice_ids)
        +payment(raw_payment)
        +calculate_net_amount(amount, discount)
        +add_strike(amount)
        +reset_strike()
        +search_contract_by_id(contractId)
        +check_status_cleaning_ticket(list)
        +create_cleaning_ticket(resident_id, room_id)
        +add_cleaning_ticket(room, cleaning_ticket)
    }

    class Contract {
        -str id
        -datetime date_create
        -Resident resident
        -Room room
        -str cancel_rent_condition
        -datetime move_in_date
        -ContractStatus status
        -int rental_time
        -float monthly_rent
        -str invoice_id
        +room()
        +resident()
        +invoice_id()
        +validate_for_signing()
        +validate_contract_status_for_handover()
        +calculate_upgrade_amount(target_cost, moveDate)
    }

    class Invoice {
        -str id
        -InvoiceType type
        -float amount
        -InvoiceStatus status
        -datetime date_create
        -str room_id
        +PAID()
        +validate_for_payment()
    }

    class Payment {
        -Payment_Method payment_method
        -list invoice_list
        -float discount
        -float net_amount
        +payment_method()
        +invoice_list()
        +net_amount()
    }

    class Receipt {
        -str id
        -Payment payment
        -datetime date_create
        +id()
    }

    class MaintenanceTicket {
        -str id
        -str reporter
        -str room_id
        -IssueCategory issue_category
        -datetime report_time
        -str responsible_technician
        -str approve_employee
        -MaintenanceStatus status
        -datetime start_time
        -datetime end_time
        -float cost
        -str notes
        +update_maintenance_status(status)
        +begin_work(notes)
        +finish_work(cost)
        +approve_maintenance(employee, status)
    }

    class CleaningTicket {
        -str id
        -str resident_id
        -str room_id
        -CleaningStatus status
        -int cost = 100
        -datetime report_time
        +id()
        +status()
    }

    class BookingShareFacility {
        -str id
        -str resident_id
        -str facility_id
        -str building_id
        -str booking_time
        -BookingShareFacilityStatus status
        +check_booking_time(facility_id, booking_time)
    }

    class Employee {
        -str id
        -str name
        -AvailabilityStatus status
        -datetime date_create
        +id()
        +start_maintenance(reporter, technicians, room, category)
        +find_available_technician(technicians)
        +create_maintenance_ticket(reporter, room_id, issue_category, technician)
        +create_contract_invoice(monthly_rent, room_id)
        +asign_member(resident, type)
    }

    class RoomBooking {
        -str id
        -Room room
        -str detail
    }

    %% ========== RELATIONSHIPS ==========

    Dorm "1" o-- "0..*" Building         : manages
    Dorm "1" o-- "0..*" Resident         : manages
    Dorm "1" o-- "0..*" Employee         : employs
    Dorm "1" o-- "0..*" Technician       : employs
    Dorm "1" o-- "0..*" Cleaner          : employs

    Building "1" *-- "0..*" Room             : contains
    Building "1" *-- "0..*" WashingMachine   : has
    Building "1" *-- "0..*" MeetingRoom      : has

    Resident "1" *-- "0..*" Contract               : holds
    Resident "1" *-- "0..*" Invoice                : has
    Resident "1" *-- "0..*" Receipt                : has
    Resident "1" *-- "0..*" CleaningTicket         : requests
    Resident "1" *-- "0..*" BookingShareFacility   : books
    Resident "1" *-- "0..*" RoomBooking            : has
    Resident "1" o-- "0..1" Member                 : subscribes
    Resident "1" o-- "0..1" Payment                : pending

    Contract "1" --> "1" Room     : occupies
    Contract "1" --> "1" Resident : belongs to

    Room "1" *-- "0..*" MaintenanceTicket  : logs
    Room "1" *-- "0..*" CleaningTicket     : logs
    Room "many" --> "1" Building           : in

    Payment "1" *-- "1"    Payment_Method  : uses
    Payment "1" *-- "1..*" Invoice         : covers
    Receipt "1" *-- "1"    Payment         : records

    Employee   "1" ..> "1"    MaintenanceTicket   : creates
    Technician "1" *-- "0..1" MaintenanceTicket   : assigned

    BookingShareFacility "many" --> "1" ShareFacility : books